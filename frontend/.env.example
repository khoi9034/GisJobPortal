# Use demo for Vercel/static demo mode.
# Use local when running the FastAPI backend at http://127.0.0.1:8001.
# Create frontend/.env.local locally and do not commit it.
NEXT_PUBLIC_APP_NAME=GIS Apply Copilot
NEXT_PUBLIC_API_MODE=demo
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Local real backend:
# NEXT_PUBLIC_API_MODE=local
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Vercel/demo:
# NEXT_PUBLIC_API_MODE=demo
