# Vercel/static demo mode:
NEXT_PUBLIC_APP_NAME=GIS Apply Copilot
NEXT_PUBLIC_API_MODE=demo

# Local real backend:
# NEXT_PUBLIC_API_MODE=api
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Vercel live backend later:
# NEXT_PUBLIC_API_MODE=api
# NEXT_PUBLIC_API_BASE_URL=https://YOUR-HOSTED-BACKEND.example.com

# Backwards compatibility: NEXT_PUBLIC_API_MODE=local also calls the API.
# Create frontend/.env.local locally and do not commit it.
